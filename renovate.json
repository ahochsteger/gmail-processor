{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],
  "dependencyDashboard": true,
  "semanticCommits": "enabled",
  "platformAutomerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "labels": ["dependencies"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 8am on saturday"]
  },
  "osvVulnerabilityAlerts": true,
  "minimumReleaseAge": "7 days",
  "internalChecksFilter": "strict",
  "schedule": ["before 8am on saturday"],
  "packageRules": [
    {
      "description": "Group all non-major dependencies into a single PR for noise reduction",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "deps:all-non-major",
      "semanticCommitType": "chore",
      "automerge": true
    },
    {
      "description": "Security vulnerability updates",
      "groupName": "deps:security",
      "matchUpdateTypes": ["vulnerability"],
      "addLabels": ["security"],
      "prPriority": 100,
      "minimumReleaseAge": "0 days",
      "automerge": true
    },
    {
      "description": "Group @types packages",
      "groupName": "deps:types",
      "matchPackagePatterns": ["^@types/"],
      "automerge": true
    },
    {
      "description": "Group @babel packages",
      "groupName": "babel monorepo",
      "matchPackagePatterns": ["^@babel/"]
    },
    {
      "description": "Group Docusaurus and React-related packages as they are tightly coupled",
      "matchPackageNames": ["react", "react-dom", "prism-react-renderer"],
      "matchPackagePatterns": ["^@docusaurus/", "^@mdx-js/"],
      "groupName": "deps:docs-docusaurus"
    },
    {
      "description": "Group eslint and typescript-eslint packages",
      "groupName": "deps:dev-eslint",
      "semanticCommitType": "build",
      "matchPackagePatterns": [
        "^@eslint/",
        "^@typescript-eslint/",
        "^eslint",
        "typescript-eslint"
      ],
      "automerge": true
    },
    {
      "description": "Group Jest packages and related test tools",
      "groupName": "deps:dev-jest",
      "semanticCommitType": "build",
      "matchPackagePatterns": ["^jest", "^@types/jest", "ts-jest", "@swc/jest"]
    },
    {
      "description": "Group Prettier packages",
      "groupName": "deps:dev-prettier",
      "semanticCommitType": "build",
      "matchPackagePatterns": ["^prettier"],
      "automerge": true
    },
    {
      "description": "Group Rollup packages and plugins",
      "groupName": "deps:dev-rollup",
      "semanticCommitType": "build",
      "matchPackagePatterns": ["^@rollup/", "rollup"]
    },
    {
      "description": "Other non-major updates for infrastructure files",
      "matchFileNames": [
        ".github/workflows/*.yaml",
        "devbox.json",
        ".devcontainer/Dockerfile"
      ],
      "groupName": "deps:infra-non-major",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "semanticCommitType": "build"
    },
    {
      "description": "Other major updates for infrastructure files",
      "matchFileNames": [
        ".github/workflows/*.yaml",
        "devbox.json",
        ".devcontainer/Dockerfile"
      ],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "semanticCommitType": "build"
    },
    {
      "description": "Lib non-major updates",
      "matchFileNames": ["package.json"],
      "groupName": "deps:lib-non-major",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "semanticCommitType": "chore",
      "automerge": true
    },
    {
      "description": "Lib major updates",
      "matchFileNames": ["package.json"],
      "matchUpdateTypes": ["major"],
      "groupName": "deps:lib-major",
      "semanticCommitType": "chore",
      "automerge": false
    },
    {
      "description": "Docs non-major updates",
      "matchFileNames": ["docs/package.json"],
      "groupName": "deps:docs-non-major",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "semanticCommitType": "chore"
    },
    {
      "description": "Docs major updates (excluding React which is in Docusaurus group)",
      "matchFileNames": ["docs/package.json"],
      "groupName": "deps:docs-major",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "semanticCommitType": "chore",
      "excludePackageNames": ["react", "react-dom"]
    }
  ]
}
