    { "type": "docs", "section": "Documentation", "hidden": false },
    { "type": "revert", "section": "Reverts", "hidden": false },
    { "type": "chore", "section": "Internal Changes", "hidden": true },
    { "type": "refactor", "section": "Internal Changes", "hidden": true },
    { "type": "test", "section": "Internal Changes", "hidden": true },
    { "type": "build", "section": "Internal Changes", "hidden": true },
    { "type": "ci", "section": "Internal Changes", "hidden": true }
  ],
  "pull-request-header": "",
