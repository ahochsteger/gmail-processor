#!/bin/sh 
# See https://www.sipios.com/blog-tech/tips-for-creating-stunning-software-releases-automatically

commit_msg=$(cat "${1:?Missing commit message file}") 

if ! echo "${commit_msg}" | grep -Eq "^(build|chore|ci|docs|feat|feat!|fix|perf|refactor|revert|style|test)(\(.+\))?: .*$" ; then 

  echo "Invalid commit message - use conventional commits: https://www.conventionalcommits.org/en/v1.0.0/" 

    exit 1 

# AI-Assisted Change Detection
if echo "${commit_msg}" | grep -Eq "AI-Assisted: true|AI-Tool:" ; then
  if [ "${ALLOW_AI_COMMIT}" != "true" ]; then
    echo "--------------------------------------------------------------------------------"
    echo "CRITICAL SAFETY WARNING: AI attribution detected in commit message."
    echo "As per the 'Safe Git Protocol' (AGENTS.md), AI agents are strictly forbidden"
    echo "from performing Git modifications."
    echo ""
    echo "If you are a HUMAN maintainer, please set ALLOW_AI_COMMIT=true to proceed."
    echo "Example: ALLOW_AI_COMMIT=true git commit -m \"...\""
    echo "--------------------------------------------------------------------------------"
    exit 1
  fi
fi

echo "Commit message is valid!"
